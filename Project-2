    <!-- ============================================================
    SCRIPTS — Popover API polyfill (minimal) + ARIA
    ============================================================ -->
    <script>
        (function() {
            'use strict';

            const toggle = document.querySelector('.nav-toggle');
            const popover = document.getElementById('nav-popover');
            const closeBtn = document.querySelector('.nav-close');
            const links = popover ? popover.querySelectorAll('a[role="menuitem"]') : [];

            // ---- Toggle aria-expanded ----
            if (toggle && popover) {
                const updateAria = () => {
                    const isOpen = popover.matches(':popover-open');
                    toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
                };

                // Observe popover attribute changes (browser sets popover attribute)
                const observer = new MutationObserver(() => updateAria());
                observer.observe(popover, { attributes: true, attributeFilter: ['popover'] });

                // Also listen for toggle clicks (browser fires before popover change)
                toggle.addEventListener('click', () => {
                    // defer to let browser update popover state
                    requestAnimationFrame(updateAria);
                });

                // Close on Escape (browser does this, but we keep aria in sync)
                document.addEventListener('keydown', (e) => {
                    if (e.key === 'Escape' && popover.matches(':popover-open')) {
                        requestAnimationFrame(updateAria);
                    }
                });

                // Close on outside click (via popover light-dismiss) — sync aria
                document.addEventListener('click', (e) => {
                    if (popover.matches(':popover-open')) {
                        const target = e.target;
                        if (!popover.contains(target) && target !== toggle && !toggle.contains(target)) {
                            requestAnimationFrame(updateAria);
                        }
                    }
                });

                // Close button
                if (closeBtn) {
                    closeBtn.addEventListener('click', () => {
                        popover.hidePopover();
                        requestAnimationFrame(updateAria);
                    });
                }

                // Close on link click (for single-page nav)
                links.forEach(link => {
                    link.addEventListener('click', () => {
                        if (window.innerWidth < 900) {
                            popover.hidePopover();
                            requestAnimationFrame(updateAria);
                        }
                    });
                });

                // Initial state
                updateAria();
            }

            // ---- Smooth scroll for anchor links (progressive enhancement) ----
            document.querySelectorAll('a[href^="#"]').forEach(anchor => {
                anchor.addEventListener('click', function(e) {
                    const href = this.getAttribute('href');
                    if (href === '#') return;
                    const target = document.querySelector(href);
                    if (target) {
                        e.preventDefault();
                        const navHeight = parseInt(getComputedStyle(document.documentElement)
                            .getPropertyValue('--nav-height')) || 64;
                        const top = target.getBoundingClientRect().top + window.pageYOffset - navHeight - 16;
                        window.scrollTo({ top, behavior: 'smooth' });
                    }
                });
            });

        })();
    </script>

